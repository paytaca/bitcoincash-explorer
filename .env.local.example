# Frontend configuration
# These are used by the Nuxt app at build time

# Chain network (mainnet or chipnet)
CHAIN=mainnet

# Site URL for SEO/meta tags
NUXT_PUBLIC_SITE_URL=https://bchexplorer.info

# IPFS gateway for NFT images (defaults to Paytaca's gateway)
NUXT_PUBLIC_IPFS_GATEWAY=https://ipfs.paytaca.com/ipfs/

# Pinata gateway token for IPFS authentication (required for paytaca.com gateway)
NUXT_PUBLIC_PINATA_GATEWAY_TOKEN=

# URLs for chain switcher
MAINNET_URL=
CHIPNET_URL=
